            "type": "dart"
        },
        {
            "name": "app_ky_service_center (profile mode)",
            "cwd": "app_ky_service_center",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "app_ky_service_center (release mode)",
            "cwd": "app_ky_service_center",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "app_ky_service_center (real device)",
            "cwd": "app_ky_service_center",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=API_BASE_URL=http://<PC-LAN-IP>:8000/api"
            ]
        }
    ]
